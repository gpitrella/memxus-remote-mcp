{
  "name": "@memxus/mcp",
  "version": "1.2.0",
  "description": "Memxus AI Context Engine — Remote MCP Server with OAuth 2.1, Streamable HTTP, GitHub/Notion sync",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --import tsx --import ./src/test/setup-env.ts --test src/**/*.test.ts scripts/*.test.mjs",
    "test:smoke": "node scripts/smoke-mcp.mjs",
    "test:smoke-v32": "node scripts/smoke-v32-total.mjs",
    "lint": "eslint src --ext .ts",
    "validate:server-json": "node scripts/validate-server-json.mjs",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "remote",
    "oauth",
    "claude",
    "memory",
    "aimemory"
  ],
  "license": "AGPL-3.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.39.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ws": "^8.18.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/ws": "^8.5.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "eslint": "^8.56.0",
    "mcp-proxy": "6.4.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
