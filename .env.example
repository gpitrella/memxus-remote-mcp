# ─── Remote MCP public URL (no trailing slash) ─────────────────────────────
MCP_PUBLIC_URL=http://localhost:3002

# ─── Dashboard public URL (used to redirect the user for login) ────────────
DASHBOARD_URL=http://localhost:3000

# ─── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...service-role-key

# ─── OpenAI (optional — enables semantic search; falls back to ILIKE) ──────
OPENAI_API_KEY=

# ─── OAuth client (pre-registered, no DCR) ─────────────────────────────────
OAUTH_CLIENT_ID=aimemory-claude
# Comma-separated allow-list of redirect URIs for Dynamic Client Registration (production)
# Add OpenAI ChatGPT Apps callback when registered at platform.openai.com/apps-manage
# Glama (also in KNOWN_MCP_REDIRECT_URIS — optional here but useful for ops visibility):
#   https://glama.ai/api/app/mcp/oauth/callback
#   https://glama.ai/mcp/inspector/oauth/callback
ALLOWED_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback,https://claude.com/api/mcp/auth_callback,http://localhost:3334/callback

# ─── CORS (comma-separated; required in production) ────────────────────────
CORS_ORIGINS=https://claude.ai,https://claude.com,https://api.anthropic.com,https://glama.ai

# Browser Origin allowlist for /mcp only (required in production)
MCP_ORIGIN_ALLOWLIST=https://claude.ai,https://claude.com,https://claudedesktop.anthropic.com,https://api.anthropic.com,https://glama.ai

PORT=3002

# Glama connector ownership (GET /.well-known/glama.json)
GLAMA_MAINTAINER_EMAIL=gabriel98_@hotmail.com

# MCP transport mode (default: stateful — required for Claude web, Smithery, Glama)
# Use stateful (false) on mcp.memxus.com with one Railway replica.
# Stateless (true) is for single-shot JSON clients only; breaks Claude tools reload + SSE.
MCP_STATELESS=false
# MCP_SESSION_TTL_MS=3600000

# Plan limits (enforced by default; set false only for local debugging)
PLAN_LIMITS_ENABLED=true
BILLING_UPGRADE_URL=https://dashboard.memxus.com/billing

# ─── Encryption (Phase 2) — must match API-IAMemory values ────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_ENCRYPTION_KEY=
ENABLE_ENCRYPTION=false
ENABLE_ENCRYPT_METADATA=true
KEYWORD_SEARCH_DECRYPT_CAP=500
